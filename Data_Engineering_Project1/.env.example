# Airflow cryptographic keys (generate your own!)
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW_JWT_SECRET=CHANGE_ME

# Project 1 DB (used by docker-compose and standalone scripts)
PROJECT1_DB_USER=airflow
PROJECT1_DB_PASSWORD=airflow

# Standalone script env vars (load_raw_food_prices.py)
DB_USER=postgres
DB_PASSWORD=CHANGE_ME
DB_HOST=localhost
DB_PORT=5432
DB_NAME=kenyan_food_prices
