# Airflow cryptographic keys (generate your own!)
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
AIRFLOW_FERNET_KEY=CHANGE_ME
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
AIRFLOW_JWT_SECRET=CHANGE_ME

# Airflow metadata DB
AIRFLOW_DB_USER=airflow
AIRFLOW_DB_PASSWORD=airflow

# Project 1 DB
PROJECT1_DB_USER=airflow
PROJECT1_DB_PASSWORD=airflow

# Project 2 DB
PROJECT2_DB_USER=postgres
PROJECT2_DB_PASSWORD=postgres

# Grafana
GF_ADMIN_USER=admin
GF_ADMIN_PASSWORD=admin
