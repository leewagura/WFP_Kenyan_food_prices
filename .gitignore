# dbt artefacts (regenerated by dbt run)
# ===========================================================
**/dbt/**/target/
**/dbt/**/dbt_packages/
**/dbt/**/logs/
**/.user.yml

# ===========================================================
# Docker volumes / data
# ===========================================================
pgdata/
pgdata_*/

# ===========================================================
# Temp files
# ===========================================================
*.tmp
_tmp_*.csv
~$*

# ===========================================================
# Word docs (not code)
# ===========================================================
*.docx

