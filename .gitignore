# ===========================================================
# Python
# ===========================================================
__pycache__/
*.pyc
*.pyo
*.egg-info/
dist/
build/
.eggs/

# ===========================================================
# Virtual environments
# ===========================================================
.venv/
venv/
env/

# ===========================================================
# IDE / Editor
# ===========================================================
.vscode/
.idea/
*.swp
*.swo

# ===========================================================
# OS generated
# ===========================================================
.DS_Store
Thumbs.db
desktop.ini

# ===========================================================
# Secrets / environment
# ===========================================================
.env

# ===========================================================
# Airflow logs (regenerated at runtime)
# ===========================================================
logs/
airflow-logs/

# ===========================================================
# Airflow runtime artifacts
# ===========================================================
config/
plugins/

